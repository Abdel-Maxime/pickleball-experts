---
interface RatingAxis {
  label: string;
  value: number; // sur 10
}

interface Props {
  axes: RatingAxis[];
  overall: number;
}

const { axes, overall } = Astro.props;
---

<div class="card overflow-hidden">
  <!-- Note globale — fond coloré -->
  <div class="bg-accent/8 border-b border-accent/15 px-5 py-4 flex items-center justify-between">
    <div>
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-0.5">Note globale</p>
      <p class="text-sm text-slate-500">Évaluation sur 5 critères</p>
    </div>
    <span class="font-mono text-4xl font-bold text-dark leading-none">
      {overall}
      <span class="text-lg text-slate-400 font-normal">/10</span>
    </span>
  </div>

  <!-- Barres par axe -->
  <div class="p-5 space-y-4">
    {axes.map(({ label, value }) => (
      <div>
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm text-slate-600">{label}</span>
          <span class="font-mono text-sm font-bold text-dark">{value}<span class="text-slate-400 font-normal">/10</span></span>
        </div>
        <div class="h-2.5 bg-slate-100 rounded-full overflow-hidden">
          <div
            class="h-full bg-accent rounded-full"
            style={`width: ${value * 10}%`}
            role="progressbar"
            aria-valuenow={value}
            aria-valuemin={0}
            aria-valuemax={10}
          />
        </div>
      </div>
    ))}
  </div>
</div>
