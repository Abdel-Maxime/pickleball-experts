---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import AffiliateButton from './AffiliateButton.astro';

interface Props {
  name: string;
  brand: string;
  image: { src: ImageMetadata; alt: string };
  price?: number;
  /** Note globale sur 10 */
  rating: number;
  affiliateUrl: string;
  amazonAsin?: string;
  pros: string[];
  cons: string[];
  /** Met en avant ce produit (badge "Meilleur choix") */
  highlighted?: boolean;
}

const {
  name,
  brand,
  image,
  price,
  rating,
  affiliateUrl,
  amazonAsin,
  pros,
  cons,
  highlighted = false,
} = Astro.props;

// Étoiles sur 5 (rating /10 → /5)
const stars = rating / 2;
const fullStars  = Math.floor(stars);
const halfStar   = stars - fullStars >= 0.5;
const emptyStars = 5 - fullStars - (halfStar ? 1 : 0);

const amazonUrl = amazonAsin
  ? `https://www.amazon.fr/dp/${amazonAsin}?tag=votre-tag-21`
  : null;
---

<div
  class:list={[
    'card overflow-hidden',
    highlighted && 'ring-2 ring-primary',
  ]}
>
  <!-- Badge "Meilleur choix" -->
  {highlighted && (
    <div class="bg-primary px-4 py-1.5 flex items-center gap-1.5">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="text-white">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      <span class="text-white text-xs font-bold uppercase tracking-wide">Meilleur choix</span>
    </div>
  )}

  <!-- Layout horizontal desktop / vertical mobile -->
  <div class="flex flex-col sm:flex-row">

    <!-- Image -->
    <div class="sm:w-48 sm:shrink-0 bg-slate-50 flex items-center justify-center p-4">
      <Image
        src={image.src}
        alt={image.alt}
        width={180}
        height={180}
        class="w-full sm:w-40 h-40 sm:h-40 object-contain"
        loading="lazy"
      />
    </div>

    <!-- Contenu -->
    <div class="flex-1 p-5 flex flex-col gap-4">

      <!-- En-tête produit -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-0.5">{brand}</p>
        <h3 class="text-lg font-bold text-dark leading-tight">{name}</h3>
        <div class="flex items-center gap-3 mt-1.5">
          <!-- Étoiles SVG -->
          <div class="flex items-center gap-0.5" role="img" aria-label={`Note : ${rating}/10`}>
            {Array.from({ length: fullStars }).map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-amber-400" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
            {halfStar && (
              <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" class="text-amber-400">
                <defs>
                  <linearGradient id="half">
                    <stop offset="50%" stop-color="currentColor"/>
                    <stop offset="50%" stop-color="transparent"/>
                  </linearGradient>
                </defs>
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#half)" stroke="currentColor" stroke-width="0.5"/>
              </svg>
            )}
            {Array.from({ length: emptyStars }).map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-300" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          <span class="font-mono text-sm font-semibold text-dark">{rating}<span class="text-slate-400 font-normal">/10</span></span>
          {price && (
            <span class="ml-auto font-mono text-lg font-bold text-dark">{price} €</span>
          )}
        </div>
      </div>

      <!-- Pros / Cons -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <p class="text-xs font-semibold text-emerald-700 uppercase tracking-wide mb-1.5">Points forts</p>
          <ul class="space-y-1 list-none m-0 p-0">
            {pros.map((pro) => (
              <li class="flex items-start gap-1.5 text-sm text-slate-600">
                <svg class="shrink-0 mt-0.5 text-emerald-500" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {pro}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold text-rose-700 uppercase tracking-wide mb-1.5">Points faibles</p>
          <ul class="space-y-1 list-none m-0 p-0">
            {cons.map((con) => (
              <li class="flex items-start gap-1.5 text-sm text-slate-600">
                <svg class="shrink-0 mt-0.5 text-rose-400" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <line x1="18" y1="6" x2="6" y2="18"/>
                  <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
                {con}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- CTA -->
      <div class="flex flex-wrap gap-2 mt-auto pt-1">
        {amazonUrl && (
          <AffiliateButton href={amazonUrl} label="Voir sur Amazon" type="amazon" />
        )}
        <AffiliateButton href={affiliateUrl} label="Voir l'offre" type="direct" />
      </div>

    </div>
  </div>
</div>
