---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { readingTime } from '../../utils/readingTime';

const categoryLabels: Record<string, string> = {
  rules: 'Règles', strategy: 'Stratégie',
  technique: 'Technique', gear: 'Équipement',
};
const levelLabels: Record<string, string> = {
  beginner: 'Débutant', intermediate: 'Intermédiaire', advanced: 'Avancé',
};

const allGuides = await getCollection('guides', ({ data }) => !data.draft);

type Category = 'rules' | 'strategy' | 'technique' | 'gear';
const categories: Category[] = ['rules', 'strategy', 'technique', 'gear'];

const sections = categories
  .map((cat) => ({
    cat,
    label: categoryLabels[cat],
    guides: allGuides
      .filter((g) => g.data.category === cat)
      .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
      .map((e) => ({
        title:       e.data.title,
        description: e.data.description,
        url:         `/guides/${e.id.replace(/\.mdx?$/, '')}/`,
        image:       e.data.image,
        date:        e.data.publishDate,
        level:       levelLabels[e.data.level] ?? e.data.level,
        readingTime: readingTime(e.body ?? ''),
      })),
  }))
  .filter((s) => s.guides.length > 0);
---

<BaseLayout
  title="Guides pickleball — Règles, techniques et stratégies"
  description="Tous nos guides pour apprendre et progresser au pickleball : règles, techniques, stratégies et équipement."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">

    <header class="mb-10">
      <p class="text-xs font-mono text-accent uppercase tracking-widest mb-2">Apprendre</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-dark mb-3">Guides pickleball</h1>
      <p class="text-slate-500 max-w-2xl">
        Règles, techniques, stratégies et conseils d'équipement pour tous les niveaux.
      </p>
    </header>

    {sections.map(({ label, guides }) => (
      <section class="mb-14">
        <h2 class="text-xl font-bold text-dark mb-5 flex items-center gap-2">
          <span class="w-1 h-5 bg-accent rounded-full inline-block" aria-hidden="true" />
          {label}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {guides.map((g) => (
            <ArticleCard
              title={g.title}
              description={g.description}
              slug={g.url}
              url={g.url}
              image={g.image}
              date={g.date}
              category={g.level}
              readingTime={g.readingTime}
            />
          ))}
        </div>
      </section>
    ))}

    {allGuides.length === 0 && (
      <p class="text-slate-400 text-sm">Aucun guide publié pour l'instant.</p>
    )}

  </div>
</BaseLayout>
