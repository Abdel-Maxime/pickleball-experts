---
import { getCollection, render } from 'astro:content';
import type { ImageMetadata } from 'astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { readingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const entries = await getCollection('guides', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '') },
    props:  { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Auteur — cast nécessaire jusqu'à la première exécution d'`astro dev` qui régénère les types
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const auteurs = await getCollection('auteurs' as any);
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const authorEntry = (auteurs as any[]).find((a) => a.id.replace(/\.mdx?$/, '') === entry.data.author);
const authorData: { name: string; role: string; shortBio: string; slug: string; avatar?: ImageMetadata } | undefined = authorEntry
  ? {
      name:     authorEntry.data.name as string,
      role:     authorEntry.data.role as string,
      shortBio: authorEntry.data.shortBio as string,
      slug:     (authorEntry.id as string).replace(/\.mdx?$/, ''),
      avatar:   authorEntry.data.avatar as ImageMetadata | undefined,
    }
  : undefined;

const categoryLabels: Record<string, string> = {
  rules: 'Règles', strategy: 'Stratégie',
  technique: 'Technique', gear: 'Équipement',
};

// Articles similaires : autres guides de même catégorie ou niveau
const allGuides = await getCollection('guides', ({ data }) => !data.draft);
const related = allGuides
  .filter((g) => {
    if (g.id === entry.id) return false;
    return g.data.category === entry.data.category || g.data.level === entry.data.level;
  })
  .slice(0, 3)
  .map((g) => ({
    title:       g.data.title,
    url:         `/guides/${g.id.replace(/\.mdx?$/, '')}/`,
    description: g.data.description,
    image:       g.data.image,
    date:        g.data.publishDate,
    category:    categoryLabels[g.data.category] ?? g.data.category,
    readingTime: readingTime(g.body ?? ''),
  }));
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.image}
  publishDate={entry.data.publishDate}
  updatedDate={entry.data.updatedDate}
  author={entry.data.author}
  collection="guides"
  collectionLabel="Guides"
  headings={headings}
  relatedArticles={related}
  authorData={authorData}
>
  <Content />
</ArticleLayout>
