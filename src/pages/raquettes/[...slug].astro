---
import { getCollection, render } from 'astro:content';
import type { ImageMetadata } from 'astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ProductBox from '../../components/ProductBox.astro';
import RatingBars from '../../components/RatingBars.astro';
import AffiliateButton from '../../components/AffiliateButton.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { readingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const entries = await getCollection('raquettes', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '') },
    props:  { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const rt = readingTime(entry.body ?? '');

// Auteur — cast nécessaire jusqu'à la première exécution d'`astro dev` qui régénère les types
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const auteurs = await getCollection('auteurs' as any);
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const authorEntry = (auteurs as any[]).find((a) => a.id.replace(/\.mdx?$/, '') === entry.data.author);
const authorData: { name: string; role: string; shortBio: string; slug: string; avatar?: ImageMetadata } | undefined = authorEntry
  ? {
      name:     authorEntry.data.name as string,
      role:     authorEntry.data.role as string,
      shortBio: authorEntry.data.shortBio as string,
      slug:     (authorEntry.id as string).replace(/\.mdx?$/, ''),
      avatar:   authorEntry.data.avatar as ImageMetadata | undefined,
    }
  : undefined;

// Articles similaires : autres paddles partageant au moins un tag
const allPaddles = await getCollection('raquettes', ({ data }) => !data.draft);
const related = allPaddles
  .filter((p) => {
    if (p.id === entry.id) return false;
    return p.data.tags.some((t) => entry.data.tags.includes(t));
  })
  .slice(0, 3)
  .map((p) => ({
    title:       p.data.title,
    url:         `/raquettes/${p.id.replace(/\.mdx?$/, '')}/`,
    description: p.data.description,
    image:       p.data.image,
    date:        p.data.publishDate,
    readingTime: readingTime(p.body ?? ''),
  }));

const ratingAxes = [
  { label: 'Puissance', value: entry.data.rating.power   },
  { label: 'Contrôle',  value: entry.data.rating.control },
  { label: 'Spin',      value: entry.data.rating.spin    },
  { label: 'Toucher',   value: entry.data.rating.touch   },
];
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.image}
  publishDate={entry.data.publishDate}
  updatedDate={entry.data.updatedDate}
  author={entry.data.author}
  collection="raquettes"
  collectionLabel="Raquettes"
  affiliateUrl={entry.data.affiliateUrl}
  headings={headings}
  relatedArticles={related}
  authorData={authorData}
>

  <!-- ProductBox en haut -->
  <ProductBox
    name={entry.data.model}
    brand={entry.data.brand}
    image={entry.data.image}
    price={entry.data.specs.price}
    rating={entry.data.rating.overall}
    affiliateUrl={entry.data.affiliateUrl}
    pros={entry.data.pros}
    cons={entry.data.cons}
    highlighted={entry.data.featured}
  />

  <!-- Tableau specs -->
  <div class="my-8 overflow-x-auto rounded-[12px] border border-slate-200">
    <table class="w-full text-sm border-collapse">
      <caption class="text-left px-4 py-2 font-semibold text-dark text-base">Caractéristiques techniques</caption>
      <tbody>
        {[
          ['Poids',       entry.data.specs.weight],
          ['Grip',        entry.data.specs.grip],
          ['Âme',         entry.data.specs.core],
          ['Surface',     entry.data.specs.face],
          ['Prix indicatif', `${entry.data.specs.price} €`],
        ].map(([label, value]) => (
          <tr class="border-t border-slate-100 even:bg-slate-50">
            <td class="px-4 py-2.5 font-medium text-slate-600 w-48">{label}</td>
            <td class="px-4 py-2.5 font-mono text-dark">{value}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Notes par axe -->
  <div class="my-8">
    <RatingBars axes={ratingAxes} overall={entry.data.rating.overall} />
  </div>

  <!-- Contenu MDX -->
  <Content />

  <!-- Verdict -->
  <div class="my-8 card p-5 bg-surface-alt border-border">
    <p class="text-xs font-mono uppercase tracking-widest text-accent mb-2">Notre verdict</p>
    <p class="text-slate-700 leading-relaxed">{entry.data.verdict}</p>
  </div>

  <!-- CTA final -->
  <div class="my-8 flex flex-wrap gap-3">
    <AffiliateButton
      href={entry.data.affiliateUrl}
      label={entry.data.affiliateUrl.includes('amazon') ? 'Voir sur Amazon' : 'Voir la meilleure offre'}
    />
  </div>

</ArticleLayout>
