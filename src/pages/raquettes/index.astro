---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { readingTime } from '../../utils/readingTime';

const BUDGET_RANGES = [
  { label: 'Moins de 80€',  min: 0,   max: 79  },
  { label: '80€ – 130€',   min: 80,  max: 130 },
  { label: '130€ – 200€',  min: 131, max: 200 },
  { label: 'Plus de 200€', min: 201, max: 99999 },
];

const levelLabels: Record<string, string> = {
  beginner: 'Débutant', intermediate: 'Intermédiaire', advanced: 'Avancé',
};

const allPaddles = await getCollection('raquettes', ({ data }) => !data.draft);

const paddles = allPaddles
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .map((e) => ({
    title:       e.data.title,
    description: e.data.description,
    url:         `/raquettes/${e.id.replace(/\.mdx?$/, '')}/`,
    image:       e.data.image,
    date:        e.data.publishDate,
    category:    e.data.brand,
    readingTime: readingTime(e.body ?? ''),
    rating:      e.data.rating.overall,
    tags:        e.data.tags.join(','),
    price:       e.data.specs.price,
  }));
---

<BaseLayout
  title="Avis raquettes de pickleball — Comparatif complet"
  description="Tous nos tests et avis détaillés de raquettes de pickleball, classés par niveau et budget."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">

    <header class="mb-10">
      <p class="text-xs font-mono text-accent uppercase tracking-widest mb-2">Équipement</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-dark mb-3">Avis sur les raquettes de pickleball</h1>
      <p class="text-slate-500 max-w-2xl">
        Tous nos tests et comparatifs de paddles, avec notes détaillées sur la puissance, le contrôle et le spin.
      </p>
    </header>

    <!-- Filtres -->
    <div class="card p-4 mb-8 flex flex-wrap gap-4 items-end">
      <div class="flex flex-col gap-1.5">
        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide" for="filter-level">Niveau</label>
        <select id="filter-level" class="text-sm border border-slate-200 rounded-lg px-3 py-2 text-dark bg-white focus:outline-none focus:ring-2 focus:ring-accent">
          <option value="">Tous niveaux</option>
          {Object.entries(levelLabels).map(([val, lbl]) => (
            <option value={val}>{lbl}</option>
          ))}
        </select>
      </div>
      <div class="flex flex-col gap-1.5">
        <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide" for="filter-budget">Budget</label>
        <select id="filter-budget" class="text-sm border border-slate-200 rounded-lg px-3 py-2 text-dark bg-white focus:outline-none focus:ring-2 focus:ring-accent">
          <option value="">Tous budgets</option>
          {BUDGET_RANGES.map((r, i) => (
            <option value={i}>{r.label}</option>
          ))}
        </select>
      </div>
      <p id="results-count" class="text-sm text-slate-400 mb-0.5 ml-auto">
        {paddles.length} raquette{paddles.length > 1 ? 's' : ''}
      </p>
    </div>

    <!-- Grille -->
    <div id="paddles-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {paddles.map((p) => (
        <div class="paddle-card" data-tags={p.tags} data-price={p.price}>
          <ArticleCard
            title={p.title}
            description={p.description}
            slug={p.url}
            url={p.url}
            image={p.image}
            date={p.date}
            category={p.category}
            readingTime={p.readingTime}
            rating={p.rating}
          />
        </div>
      ))}
    </div>

    {paddles.length === 0 && (
      <p class="text-slate-400 text-sm">Aucune raquette publiée pour l'instant.</p>
    )}
    <p id="empty-state" class="hidden text-center text-slate-400 py-16">
      Aucune raquette ne correspond à ces critères.
    </p>

  </div>
</BaseLayout>

<script is:inline define:vars={{ budgetRanges: BUDGET_RANGES.map((r) => ({ min: r.min, max: r.max })) }}>
  const levelSelect  = /** @type {HTMLSelectElement} */ (document.getElementById('filter-level'));
  const budgetSelect = /** @type {HTMLSelectElement} */ (document.getElementById('filter-budget'));
  const grid         = document.getElementById('paddles-grid');
  const emptyState   = document.getElementById('empty-state');
  const countEl      = document.getElementById('results-count');
  const cards        = /** @type {HTMLElement[]} */ (Array.from(document.querySelectorAll('.paddle-card')));

  function applyFilters() {
    const level  = levelSelect.value;
    const budget = budgetSelect.value;
    let visible  = 0;

    cards.forEach((card) => {
      const tags  = card.dataset.tags ? card.dataset.tags.split(',') : [];
      const price = parseFloat(card.dataset.price ?? '0');
      const levelOk  = !level || tags.includes(level);
      const range    = budget !== '' ? budgetRanges[parseInt(budget, 10)] : null;
      const budgetOk = !range || (price >= range.min && price <= range.max);

      const show = levelOk && budgetOk;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    const isEmpty = visible === 0 && cards.length > 0;
    emptyState.classList.toggle('hidden', !isEmpty);
    if (grid) grid.classList.toggle('hidden', isEmpty);
    if (countEl) countEl.textContent = `${visible} raquette${visible > 1 ? 's' : ''}`;
  }

  levelSelect.addEventListener('change', applyFilters);
  budgetSelect.addEventListener('change', applyFilters);
</script>
