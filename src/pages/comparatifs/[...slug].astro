---
import { getCollection, render } from 'astro:content';
import type { ImageMetadata } from 'astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import { readingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const entries = await getCollection('comparatifs', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '') },
    props:  { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Auteur — cast nécessaire jusqu'à la première exécution d'`astro dev` qui régénère les types
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const auteurs = await getCollection('auteurs' as any);
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const authorEntry = (auteurs as any[]).find((a) => a.id.replace(/\.mdx?$/, '') === entry.data.author);
const authorData: { name: string; role: string; shortBio: string; slug: string; avatar?: ImageMetadata } | undefined = authorEntry
  ? {
      name:     authorEntry.data.name as string,
      role:     authorEntry.data.role as string,
      shortBio: authorEntry.data.shortBio as string,
      slug:     (authorEntry.id as string).replace(/\.mdx?$/, ''),
      avatar:   authorEntry.data.avatar as ImageMetadata | undefined,
    }
  : undefined;

// Première URL affiliée trouvée parmi les produits (pour le banner disclosure)
const firstAffiliateUrl = entry.data.products[0]?.affiliateUrl;

// Articles similaires : autres comparatifs
const allComparisons = await getCollection('comparatifs', ({ data }) => !data.draft);
const related = allComparisons
  .filter((c) => {
    if (c.id === entry.id) return false;
    return c.data.tags.some((t) => entry.data.tags.includes(t));
  })
  .slice(0, 3)
  .map((c) => ({
    title:       c.data.title,
    url:         `/comparatifs/${c.id.replace(/\.mdx?$/, '')}/`,
    description: c.data.description,
    image:       c.data.image,
    date:        c.data.publishDate,
    readingTime: readingTime(c.body ?? ''),
  }));
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.image}
  publishDate={entry.data.publishDate}
  updatedDate={entry.data.updatedDate}
  author={entry.data.author}
  collection="comparatifs"
  collectionLabel="Comparatifs"
  affiliateUrl={firstAffiliateUrl}
  headings={headings}
  relatedArticles={related}
  authorData={authorData}
>

  <!-- Tableau comparatif en haut -->
  <ComparisonTable products={entry.data.products} verdict={entry.data.verdict} />

  <!-- Contenu MDX -->
  <Content />

</ArticleLayout>
