---
import { getCollection, render } from 'astro:content';
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { readingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  const auteurs = await getCollection('auteurs' as any) as any[];
  return auteurs.map((entry: any) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '') },
    props:  { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry as any);
const slug = entry.id.replace(/\.mdx?$/, '');

const { name, role, shortBio, avatar, social } = entry.data as {
  name: string;
  role: string;
  shortBio: string;
  avatar?: ImageMetadata;
  social?: { twitter?: string; linkedin?: string; instagram?: string };
};

const initials = name
  .split(' ')
  .map((w: string) => w[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();

// Articles de cet auteur (toutes collections)
const [raquettes, guides, comparatifs] = await Promise.all([
  getCollection('raquettes', ({ data }) => !data.draft && data.author === slug),
  getCollection('guides',    ({ data }) => !data.draft && data.author === slug),
  getCollection('comparatifs', ({ data }) => !data.draft && data.author === slug),
]);

const allArticles = [
  ...raquettes.map((e) => ({
    title:       e.data.title,
    description: e.data.description,
    url:         `/raquettes/${e.id.replace(/\.mdx?$/, '')}/`,
    image:       e.data.image,
    date:        e.data.publishDate,
    category:    e.data.brand,
    readingTime: readingTime(e.body ?? ''),
  })),
  ...guides.map((e) => ({
    title:       e.data.title,
    description: e.data.description,
    url:         `/guides/${e.id.replace(/\.mdx?$/, '')}/`,
    image:       e.data.image,
    date:        e.data.publishDate,
    category:    'Guide',
    readingTime: readingTime(e.body ?? ''),
  })),
  ...comparatifs.map((e) => ({
    title:       e.data.title,
    description: e.data.description,
    url:         `/comparatifs/${e.id.replace(/\.mdx?$/, '')}/`,
    image:       e.data.image,
    date:        e.data.publishDate,
    category:    'Comparatif',
    readingTime: readingTime(e.body ?? ''),
  })),
].sort((a, b) => b.date.getTime() - a.date.getTime());
---

<BaseLayout title={`${name} — Profil auteur`} description={shortBio}>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-16">

    <!-- Breadcrumb -->
    <nav aria-label="Fil d'Ariane" class="mb-8">
      <ol class="flex items-center gap-1.5 text-sm text-muted list-none m-0 p-0 flex-wrap">
        <li><a href="/" class="hover:text-accent transition-colors">Accueil</a></li>
        <li aria-hidden="true" class="text-slate-300">/</li>
        <li class="text-dark font-medium" aria-current="page">{name}</li>
      </ol>
    </nav>

    <!-- En-tête auteur -->
    <header class="flex flex-col sm:flex-row items-start sm:items-center gap-6 mb-10">
      <!-- Avatar -->
      {avatar ? (
        <Image
          src={avatar}
          alt={`Photo de ${name}`}
          width={96}
          height={96}
          class="w-24 h-24 rounded-full object-cover shrink-0"
          loading="eager"
        />
      ) : (
        <div
          class="w-24 h-24 rounded-full bg-primary flex items-center justify-center text-white font-display font-bold text-2xl shrink-0 select-none"
          aria-hidden="true"
        >
          {initials}
        </div>
      )}

      <div>
        <p class="text-xs font-mono uppercase tracking-widest text-accent mb-1">{role}</p>
        <h1 class="text-3xl sm:text-4xl font-display font-bold text-dark leading-tight mb-2">{name}</h1>
        <p class="text-muted leading-relaxed">{shortBio}</p>

        <!-- Liens sociaux -->
        {social && (
          <div class="flex items-center gap-4 mt-3">
            {social.twitter && (
              <a href={social.twitter} rel="noopener noreferrer" target="_blank"
                 class="text-xs font-mono uppercase tracking-wider text-muted hover:text-accent transition-colors">
                Twitter / X
              </a>
            )}
            {social.linkedin && (
              <a href={social.linkedin} rel="noopener noreferrer" target="_blank"
                 class="text-xs font-mono uppercase tracking-wider text-muted hover:text-accent transition-colors">
                LinkedIn
              </a>
            )}
            {social.instagram && (
              <a href={social.instagram} rel="noopener noreferrer" target="_blank"
                 class="text-xs font-mono uppercase tracking-wider text-muted hover:text-accent transition-colors">
                Instagram
              </a>
            )}
          </div>
        )}
      </div>
    </header>

    <!-- Séparateur -->
    <hr class="border-border mb-10" />

    <!-- Bio MDX -->
    <div class="prose prose-slate max-w-none
                prose-headings:font-display prose-headings:font-bold prose-headings:text-dark
                prose-a:text-accent prose-a:no-underline hover:prose-a:underline
                prose-blockquote:border-l-4 prose-blockquote:border-accent prose-blockquote:not-italic
                mb-14">
      <Content />
    </div>

    <!-- Articles de l'auteur -->
    {allArticles.length > 0 && (
      <section class="border-t border-border pt-10">
        <p class="text-xs font-mono uppercase tracking-widest text-accent mb-2">Publications</p>
        <h2 class="text-2xl font-display font-bold text-dark mb-6">
          Articles de {name}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {allArticles.map((article) => (
            <ArticleCard
              title={article.title}
              description={article.description}
              slug={article.url}
              url={article.url}
              image={article.image}
              date={article.date}
              category={article.category}
              readingTime={article.readingTime}
            />
          ))}
        </div>
      </section>
    )}

    {allArticles.length === 0 && (
      <p class="text-muted text-sm">Aucun article publié pour l'instant.</p>
    )}

  </div>

</BaseLayout>
